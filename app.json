{
  "name": "ARYAN-MD",
  "description": "ARYAN-TECH — A Powerful WhatsApp Bot built with Node.js.",
  "repository": "https://github.com/aryankingkilalu/ARYAN-MD",
  "keywords": ["whatsapp", "bot", "baileys", "node"],
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID. Format: Aryan-X:~<base64>",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql"
    }
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ]
}
